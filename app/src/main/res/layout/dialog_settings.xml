<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#ffffff">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="VLM API URL"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#1a1a1a"
        android:layout_marginBottom="8dp" />

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/et_api_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="http://192.168.1.46:8080/v1/chat/completions"
        android:inputType="textUri"
        android:padding="12dp"
        android:background="#e0e0e0"
        android:textColor="#000000"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Model Name"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#1a1a1a"
        android:layout_marginBottom="8dp" />

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/et_model"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="unsloth/Qwen3.5-122B-A10B-GGUF:UD-Q4_K_XL"
        android:inputType="text"
        android:padding="12dp"
        android:background="#e0e0e0"
        android:textColor="#000000"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Changes take effect on next capture"
        android:textSize="12sp"
        android:textColor="#666666" />

</LinearLayout>
